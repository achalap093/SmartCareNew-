{
  "name": "smartcare-server",
  "version": "1.0.0",
  "description": "SmartCare Hospital Management Backend (MVC, MERN)",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node --test --experimental-test-isolation=none tests/unit/**/*.test.js",
    "test:jest": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:jest:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "echo \"Add eslint config\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.1",
    "morgan": "^1.10.0",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}
